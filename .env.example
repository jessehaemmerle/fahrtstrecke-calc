# ── Valhalla-Konfiguration ──────────────────────────────────────────────────
#
# ERSTES DEPLOYMENT (Server):
#   1. Diese Datei nach .env kopieren
#   2. Werte anpassen (VALHALLA_TILE_URL aktiv lassen)
#   3. docker compose up -d
#      → Valhalla lädt das PBF automatisch herunter und baut Tiles (~2h)
#
# NACH DEM ERSTEN BUILD (alle weiteren Starts):
#   VALHALLA_TILE_URL auskommentieren, USE_TILES_IGNORE_PBF=True setzen
#   → Tiles werden direkt geladen, kein Rebuild

# URL zur OpenStreetMap-Datei (nur beim ersten Build benötigt)
# Österreich ~765 MB:
VALHALLA_TILE_URL=https://download.geofabrik.de/europe/austria-latest.osm.pbf
# DACH (Deutschland/Österreich/Schweiz) ~3.5 GB:
# VALHALLA_TILE_URL=https://download.geofabrik.de/europe/dach-latest.osm.pbf

# Nach erstem Build auf True setzen:
USE_TILES_IGNORE_PBF=False

# Auf True lassen für ersten Build (erstellt valhalla_tiles.tar):
BUILD_TAR=True

# Längere Healthcheck-Wartezeit für ersten Build (~2h):
VALHALLA_START_PERIOD=7200s
