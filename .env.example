# ── Stadia Maps API-Key ─────────────────────────────────────────────────────
# Kostenlos registrieren (200.000 Anfragen/Monat gratis):
# https://client.stadiamaps.com/signup/
STADIA_API_KEY=dein_api_key_hier

# ── Lokales Valhalla (optional) ──────────────────────────────────────────────
# Nur nötig wenn der valhalla-Service in compose.yaml aktiviert ist.
#
# ERSTES DEPLOYMENT:
#   USE_TILES_IGNORE_PBF=False
#   BUILD_TAR=True
#   VALHALLA_START_PERIOD=7200s
#   VALHALLA_TILE_URL=https://download.geofabrik.de/europe/austria-latest.osm.pbf
#
# NACH DEM ERSTEN BUILD:
#   USE_TILES_IGNORE_PBF=True
#   BUILD_TAR=False
#   VALHALLA_START_PERIOD=120s
#   VALHALLA_TILE_URL=

USE_TILES_IGNORE_PBF=True
BUILD_TAR=False
VALHALLA_START_PERIOD=120s
VALHALLA_TILE_URL=
